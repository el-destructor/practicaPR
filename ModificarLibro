package es.studium.LoginLibros;

import java.awt.*;
import java.awt.event.*;
import java.sql.*;

public class ModificarLibro extends Frame implements WindowListener, ActionListener 
{
	private static final long serialVersionUID = 1L;

	Choice choBuscar = new Choice();
	Button btnCargar = new Button("Cargar");
	TextField txtNom = new TextField();
	TextField txtGen = new TextField();
	TextField txtPre = new TextField();
	Choice choEditorial = new Choice();
	Button btnModificar = new Button("Guardar Cambios");

	public ModificarLibro() 
	{
		setLayout(null);
		setTitle("Modificar Libro");

		choBuscar.setBounds(30, 45, 200, 25);  
		btnCargar.setBounds(240, 45, 80, 25);
		txtNom.setBounds(140, 90, 180, 25);
		txtGen.setBounds(140, 130, 180, 25);
		txtPre.setBounds(140, 170, 180, 25);
		choEditorial.setBounds(140, 210, 180, 25);
		btnModificar.setBounds(110, 255, 140, 30);

		cargarComboLibros();
		cargarComboEditoriales();

		add(choBuscar); add(btnCargar); add(txtNom); add(txtGen); add(txtPre); add(choEditorial); add(btnModificar);

		btnCargar.addActionListener(this);
		btnModificar.addActionListener(this);
		addWindowListener(this);

		setSize(360, 310);
		setResizable(false);
		setLocationRelativeTo(null);
		setVisible(true);
	}

	private void cargarComboLibros() 
	{
		try (Connection con = ConexionBD.conectar(); 
			 Statement st = con.createStatement(); 
			 ResultSet rs = st.executeQuery("SELECT idLibro, nombreLibro FROM libros")) {
			while (rs.next()) choBuscar.add(rs.getInt("idLibro") + " - " + rs.getString("nombreLibro"));
		} catch (Exception e) {}
	}

	private void cargarComboEditoriales() 
	{
		try (Connection con = ConexionBD.conectar(); 
			 Statement st = con.createStatement(); 
			 ResultSet rs = st.executeQuery("SELECT idEditorial, nombreEditorial FROM editoriales")) {
			while (rs.next()) choEditorial.add(rs.getInt("idEditorial") + " - " + rs.getString("nombreEditorial"));
		} catch (Exception e) {}
	}

	public void actionPerformed(ActionEvent e) 
	{
		Object src = e.getSource();
		if (src.equals(btnCargar)) 
		{
			if (choBuscar.getSelectedItem() == null) return;
			int idSeleccionado = Integer.parseInt(choBuscar.getSelectedItem().split(" - ")[0]);
			
			try (Connection con = ConexionBD.conectar(); 
				 PreparedStatement pst = con.prepareStatement("SELECT nombreLibro, generoLibro, precioLibro FROM libros WHERE idLibro = ?")) {
				pst.setInt(1, idSeleccionado);
				ResultSet rs = pst.executeQuery();
				if (rs.next()) {
					txtNom.setText(rs.getString("nombreLibro"));
					txtGen.setText(rs.getString("generoLibro"));
					txtPre.setText(String.valueOf(rs.getDouble("precioLibro")));
				}
			} catch(Exception ex) {}
		} 
		else if (src.equals(btnModificar)) 
		{
			if (choBuscar.getSelectedItem() == null) return;
			int idLibro = Integer.parseInt(choBuscar.getSelectedItem().split(" - ")[0]);
			int fkEditorial = Integer.parseInt(choEditorial.getSelectedItem().split(" - ")[0]);
			
			String query = "UPDATE libros SET nombreLibro=?, generoLibro=?, precioLibro=?, idEditorialFK=? WHERE idLibro=?";
			try (Connection con = ConexionBD.conectar(); 
				 PreparedStatement pst = con.prepareStatement(query)) {
				pst.setString(1, txtNom.getText());
				pst.setString(2, txtGen.getText());
				pst.setDouble(3, Double.parseDouble(txtPre.getText()));
				pst.setInt(4, fkEditorial);
				pst.setInt(5, idLibro);
				pst.executeUpdate();
				
				LogUtil.registrarAccion(Login.usuarioActual, "Modifico Libro ID: " + idLibro);
				this.dispose();
			} catch(Exception ex) {}
		}
	}

	public void windowClosing(WindowEvent e) { this.dispose(); }
	public void windowActivated(WindowEvent e) {}
	public void windowClosed(WindowEvent e) {}
	public void windowDeactivated(WindowEvent e) {}
	public void windowDeiconified(WindowEvent e) {}
	public void windowIconified(WindowEvent e) {}
	public void windowOpened(WindowEvent e) {}
}
