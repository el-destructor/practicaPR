package es.studium.LoginLibros;

import java.awt.*;
import java.awt.event.*;
import java.sql.*;

public class ModificarEscritor extends Frame implements WindowListener, ActionListener 
{
	private static final long serialVersionUID = 1L;

	Choice choBuscar = new Choice();
	Button btnCargar = new Button("Cargar");
	TextField txtNom = new TextField();
	TextField txtApe = new TextField();
	TextField txtFecha = new TextField();
	Button btnModificar = new Button("Guardar Cambios");

	public ModificarEscritor() 
	{
		setLayout(null);
		setTitle("Modificar Escritor");

		choBuscar.setBounds(30, 45, 200, 25);  
		btnCargar.setBounds(240, 45, 80, 25);
		txtNom.setBounds(140, 90, 180, 25);
		txtApe.setBounds(140, 130, 180, 25);
		txtFecha.setBounds(140, 170, 180, 25);
		btnModificar.setBounds(110, 215, 140, 30);

		cargarComboEscritores();

		add(choBuscar); add(btnCargar); add(txtNom); add(txtApe); add(txtFecha); add(btnModificar);

		btnCargar.addActionListener(this);
		btnModificar.addActionListener(this);
		addWindowListener(this);

		setSize(360, 270);
		setResizable(false);
		setLocationRelativeTo(null);
		setVisible(true);
	}

	private void cargarComboEscritores() 
	{
		try (Connection con = ConexionBD.conectar(); 
			 Statement st = con.createStatement(); 
			 ResultSet rs = st.executeQuery("SELECT idEscritor, nombreEscritor, apellidosEscritor FROM escritores")) {
			while (rs.next()) choBuscar.add(rs.getInt("idEscritor") + " - " + rs.getString("nombreEscritor") + " " + rs.getString("apellidosEscritor"));
		} catch (Exception e) {}
	}

	public void actionPerformed(ActionEvent e) 
	{
		Object src = e.getSource();
		if (src.equals(btnCargar)) 
		{
			if (choBuscar.getSelectedItem() == null) return;
			int idSeleccionado = Integer.parseInt(choBuscar.getSelectedItem().split(" - ")[0]);
			
			try (Connection con = ConexionBD.conectar(); 
				 PreparedStatement pst = con.prepareStatement("SELECT nombreEscritor, apellidosEscritor, fechaNacimientoEscritor FROM escritores WHERE idEscritor = ?")) {
				pst.setInt(1, idSeleccionado);
				ResultSet rs = pst.executeQuery();
				if (rs.next()) {
					txtNom.setText(rs.getString("nombreEscritor"));
					txtApe.setText(rs.getString("apellidosEscritor"));
					txtFecha.setText(rs.getString("fechaNacimientoEscritor"));
				}
			} catch(Exception ex) {}
		} 
		else if (src.equals(btnModificar)) 
		{
			if (choBuscar.getSelectedItem() == null) return;
			int idEscritor = Integer.parseInt(choBuscar.getSelectedItem().split(" - ")[0]);
			
			String query = "UPDATE escritores SET nombreEscritor=?, apellidosEscritor=?, fechaNacimientoEscritor=? WHERE idEscritor=?";
			try (Connection con = ConexionBD.conectar(); 
				 PreparedStatement pst = con.prepareStatement(query)) {
				pst.setString(1, txtNom.getText().trim());
				pst.setString(2, txtApe.getText().trim());
				pst.setString(3, txtFecha.getText().trim());
				pst.setInt(4, idEscritor);
				pst.executeUpdate();
				
				LogUtil.registrarAccion(Login.usuarioActual, "Modifico Escritor ID: " + idEscritor);
				this.dispose();
			} catch(Exception ex) {}
		}
	}

	public void windowClosing(WindowEvent e) { this.dispose(); }
	public void windowActivated(WindowEvent e) {}
	public void windowClosed(WindowEvent e) {}
	public void windowDeactivated(WindowEvent e) {}
	public void windowDeiconified(WindowEvent e) {}
	public void windowIconified(WindowEvent e) {}
	public void windowOpened(WindowEvent e) {}
}
